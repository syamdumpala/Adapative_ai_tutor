# =============================================================================
# Frontend environment template  —  copy to `.env.local` and fill in real values
# =============================================================================
#
# SECURITY RULES (see docs/security/SECURITY.md):
#   1. NEVER commit a real `.env.local`. Only this template is tracked.
#   2. Any variable prefixed with `NEXT_PUBLIC_` is INLINED INTO THE BROWSER
#      BUNDLE and is therefore PUBLIC. Never put secrets (API keys, tokens,
#      passwords) behind a `NEXT_PUBLIC_` name.
#   3. Server-only secrets must NOT use the `NEXT_PUBLIC_` prefix. Read them only
#      in Server Components, Route Handlers, or Server Actions.
#   4. Talk to the backend through a server-side proxy/route where possible so
#      backend secrets never reach the client.
# -----------------------------------------------------------------------------

# ---- Public (safe to expose to the browser) --------------------------------
# Base URL of the backend API as seen by the browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ---- Server-only (NEVER prefixed with NEXT_PUBLIC_) ------------------------
# Backend base URL used by the BFF route handlers (`/api/*`) to reach FastAPI.
# The browser never uses this — it only calls same-origin `/api/*`. Falls back to
# NEXT_PUBLIC_API_BASE_URL then http://localhost:8000 when unset.
API_BASE_URL=http://localhost:8000

# Example server-side secret. Consumed only in server code, never shipped to the
# client bundle. Leave blank here; set the real value in `.env.local`.
# BACKEND_API_KEY=
