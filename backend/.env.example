# ─────────────────────────────────────────────────────────────────────────────
# Database — PostgreSQL (async driver). Adjust user/password/host/db as needed.
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://localhost:5432/adaptive_tutor

# ─────────────────────────────────────────────────────────────────────────────
# JWT auth
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─────────────────────────────────────────────────────────────────────────────
# LLM provider — everything below is env-driven, so moving dev -> prod is a
# config change, not a code change (see app/core/llm.py).
#
#   LLM_PROVIDER    which vendor:  anthropic | openai | google
#   LLM_AUTH_MODE   Anthropic only: subscription | api_key
#                     subscription -> uses CLAUDE_CODE_OAUTH_TOKEN (no paid tokens)
#                     api_key      -> uses ANTHROPIC_API_KEY (billed)
#                   (ignored for openai / google — those are always api_key)
#   LLM_MODEL       any model the chosen provider supports; applies in
#                   subscription mode too (e.g. claude-sonnet-5 vs claude-opus-4-8)
# ─────────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic
LLM_AUTH_MODE=subscription
LLM_MODEL=claude-opus-4-8

# --- Development: Claude Pro/Max subscription (no API tokens spent) -----------
# Generate once with:  claude setup-token   (requires the Claude Code CLI)
# DEV ONLY — a subscription does not include API access; do not ship this token.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# --- Production: first-party API keys (set the one matching LLM_PROVIDER) -----
# Anthropic  (LLM_PROVIDER=anthropic, LLM_AUTH_MODE=api_key)
ANTHROPIC_API_KEY=sk-ant-...
# OpenAI     (LLM_PROVIDER=openai,  LLM_MODEL=gpt-4o)
OPENAI_API_KEY=sk-...
# Gemini     (LLM_PROVIDER=google,  LLM_MODEL=gemini-2.5-pro)
GOOGLE_API_KEY=...

# Example — dev on the subscription with a cheaper model:
#   LLM_PROVIDER=anthropic / LLM_AUTH_MODE=subscription / LLM_MODEL=claude-sonnet-5
# Example — test the production Anthropic key with no other changes:
#   LLM_AUTH_MODE=api_key   (ANTHROPIC_API_KEY must be set)
